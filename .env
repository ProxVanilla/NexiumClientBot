# Discord Bot credentials
DISCORD_TOKEN=process.env.DISCORD_TOKEN
CLIENT_ID=1528848840428490772
GUILD_ID=1528652779923701770

# Optional: restrict slash-command deploy to a single guild during dev (leave blank for global)
DEPLOY_GUILD_ONLY=true

# Branding
BOT_NAME=NexiumClient
SERVER_NAME=NexiumClient
BOT_PREFIX=!
EMBED_COLOR=#9B59B6

# Staff roles (by exact role NAME, comma-separated) - these get bot-staff access
# in addition to native Discord permissions like Ban Members / Kick Members / etc.
STAFF_ROLE_NAMES=mod,Drmelonn,Nexium

# Role granted to members when they verify
VERIFIED_ROLE_NAME=Member

# Ticket system
TICKET_CATEGORY_ID=
TICKET_LOG_CHANNEL_ID=
TICKET_SUPPORT_ROLE_ID=

# Levels
LEVEL_UP_CHANNEL_ID=

# Prices service (CoinGecko has a free public API, no key required by default)
PRICE_API_BASE=https://api.coingecko.com/api/v3

# Database
DATABASE_PATH=./database/nexium.sqlite
